---
interface Props {
  href: string;
  title: string;
}

const { href, title } = Astro.props;
---

<li>
  <a
    href={href}
    class="pb-1 text-yellow-100 hover:text-yellow font-bold bg-left-bottom bg-gradient-to-r from-yellow to-yellow bg-[length:0%_2px] bg-no-repeat hover:bg-[length:100%_2px] transition-all duration-300 ease-out"
  >
    {title}
  </a>
</li>

<style>
  .underline {
    background-image: linear-gradient;
  }
</style>
